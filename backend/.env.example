PORT=3000

# Secret used to sign courier auth tokens (use a long random string in production)
JWT_SECRET=replace-with-a-secure-secret

# Postgres connection string.
# Locally you can instead set DB_USER, DB_PASSWORD, DB_HOST, DB_PORT, DB_NAME.
# For a hosted DB (Neon, Render, Railway, Supabase, etc.) set DATABASE_URL.
# Example: postgresql://user:password@localhost:5432/delivery_buddy
DATABASE_URL=

# Uncomment + set these for a local Postgres instance if not using DATABASE_URL.
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=delivery_buddy

# Set to "true" when the DB requires SSL (e.g. Neon, most cloud providers).
DATABASE_SSL=true

# Optional: dedicated database used by the test suite (falls back to DATABASE_URL).
# TEST_DATABASE_URL=