@backend = http://localhost:3000/api

### Sign up
# @name signup
POST {{backend}}/auth/signup
Content-Type: application/json

{
  "email": "demo@example.com",
  "password": "password123",
  "name": "Demo Courier"
}

### Login — grab the token from the response and paste it into @token below
# @name login
POST {{backend}}/auth/login
Content-Type: application/json

{
  "email": "demo@example.com",
  "password": "password123"
}

@token = <your-token-here>

### Get profile
GET {{backend}}/courier/me
Authorization: Bearer {{token}}

### Edit profile name
PATCH {{backend}}/courier/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Demo Courier"
}

### Get settings
GET {{backend}}/courier/settings
Authorization: Bearer {{token}}

### Start shift
POST {{backend}}/shifts/start
Authorization: Bearer {{token}}

### Current shift
GET {{backend}}/shifts/current
Authorization: Bearer {{token}}

### Last shift
GET {{backend}}/shifts/last
Authorization: Bearer {{token}}

### Stop shift
POST {{backend}}/shifts/stop
Authorization: Bearer {{token}}

### Current order
GET {{backend}}/orders/current
Authorization: Bearer {{token}}

### Wallet balance
GET {{backend}}/wallet
Authorization: Bearer {{token}}

### Wallet transactions
GET {{backend}}/wallet/transactions?page=1&limit=20
Authorization: Bearer {{token}}

### Withdraw
POST {{backend}}/wallet/withdraw
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 50
}

### Logout
POST {{backend}}/auth/logout
Authorization: Bearer {{token}}